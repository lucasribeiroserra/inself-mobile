# API do backend (obrigatório para persistir em PostgreSQL)
# Ex.: http://localhost:3000 ou https://sua-api.com
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google OAuth (para "Entrar com Google") - criar em https://console.cloud.google.com/
# Use o mesmo Client ID (Web) no backend em GOOGLE_CLIENT_IDS
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Opcional: para app standalone iOS/Android
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
